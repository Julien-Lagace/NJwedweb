---
// Full-screen hero background that blurs on scroll
import { Image } from 'astro:assets';
import coverPageImg from '../assets/images/cover_page.jpg';
import njLogoImg from '../assets/images/NJ_logo_white.png';
---
<section id="hero" class="hero-bg fixed inset-0 z-30">
  <!-- Background image -->
  <div class="absolute inset-0">
    <Image
      src={coverPageImg}
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
    />
    <!-- Gradient overlays for text readability -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-transparent to-black/50"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/10 via-transparent to-black/10"></div>
  </div>

  <!-- Centered logo with scroll indicator -->
  <div class="relative z-10 flex flex-col items-center justify-between h-full pb-16 px-4">
    <!-- Spacer to center logo -->
    <div class="flex-1"></div>

    <!-- Centered logo -->
    <Image
      src={njLogoImg}
      alt="NJ Logo"
      class="max-w-sm sm:max-w-md md:max-w-lg"
    />

    <!-- Spacer to push scroll indicator down -->
    <div class="flex-1"></div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator flex flex-col items-center gap-2">
      <span class="text-off-white/50 text-[10px] sm:text-xs tracking-[0.25em] uppercase font-body">
        Scroll to continue
      </span>
      <svg class="w-5 h-5 text-off-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>